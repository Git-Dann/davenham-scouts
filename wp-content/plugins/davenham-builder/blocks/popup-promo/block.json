{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/popup-promo",
  "version": "1.0.0",
  "title": "Popup Promo",
  "category": "davenham",
  "description": "A simple modal popup with a trigger button.",
  "icon": "megaphone",
  "keywords": [
    "popup",
    "modal",
    "promo",
    "announcement"
  ],
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Open popup"
    },
    "buttonText": {
      "type": "string",
      "default": "Open details"
    },
    "body": {
      "type": "string",
      "default": ""
    }
  }
}
