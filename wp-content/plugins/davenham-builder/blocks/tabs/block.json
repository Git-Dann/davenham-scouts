{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/tabs",
  "version": "1.0.0",
  "title": "Tabs",
  "category": "davenham",
  "description": "Tabbed content panels.",
  "icon": "menu-alt",
  "keywords": [
    "tabs",
    "tabbed",
    "panels",
    "switcher"
  ],
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Explore by topic"
    },
    "items": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    }
  }
}
