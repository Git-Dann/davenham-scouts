{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/steps",
  "version": "1.0.0",
  "title": "Steps / Process",
  "category": "davenham",
  "description": "A clean step-by-step process layout.",
  "icon": "list-view",
  "keywords": [
    "steps",
    "how-to",
    "process",
    "numbered"
  ],
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": "How it works"
    },
    "items": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    }
  }
}
