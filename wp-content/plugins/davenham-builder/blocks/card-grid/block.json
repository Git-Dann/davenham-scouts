{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/card-grid",
  "version": "1.0.0",
  "title": "Card Grid",
  "category": "davenham",
  "description": "Flexible cards with optional images and buttons.",
  "icon": "screenoptions",
  "keywords": [
    "cards",
    "grid",
    "columns",
    "tiles"
  ],
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Explore more"
    },
    "cards": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    }
  }
}
