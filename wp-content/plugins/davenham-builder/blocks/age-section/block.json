{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/age-section",
  "version": "1.0.0",
  "title": "Age Section",
  "category": "davenham",
  "description": "Six age-group blocks (Squirrels → Network) with SVG icons from the theme.",
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Aged 6 to 25?"
    },
    "showSquirrels": { "type": "boolean", "default": true },
    "showBeavers":   { "type": "boolean", "default": true },
    "showCubs":      { "type": "boolean", "default": true },
    "showScouts":    { "type": "boolean", "default": true },
    "showExplorers": { "type": "boolean", "default": true },
    "showNetwork":   { "type": "boolean", "default": true }
  }
}
