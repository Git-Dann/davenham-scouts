{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/video-embed",
  "version": "1.0.0",
  "title": "Video",
  "category": "davenham",
  "description": "YouTube or Vimeo embed with optional heading and caption.",
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading":  { "type": "string", "default": "" },
    "videoUrl": { "type": "string", "default": "" },
    "caption":  { "type": "string", "default": "" }
  }
}
