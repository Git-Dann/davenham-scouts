{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/key-facts",
  "version": "1.0.0",
  "title": "Key Facts",
  "category": "davenham",
  "description": "Short label and value facts in a structured grid.",
  "icon": "info-outline",
  "keywords": [
    "facts",
    "info",
    "stats",
    "highlights"
  ],
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Key facts"
    },
    "items": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    }
  }
}
