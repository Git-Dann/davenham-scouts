{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/hero",
  "version": "1.0.0",
  "title": "Hero Section",
  "category": "davenham",
  "description": "Full-width hero with background image, heading, subtext and CTA buttons.",
  "icon": "cover-image",
  "keywords": [
    "hero",
    "banner",
    "header",
    "splash"
  ],
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": "We help young people gain the skills they need to shine bright"
    },
    "subtext": {
      "type": "string",
      "default": ""
    },
    "backgroundImageUrl": {
      "type": "string",
      "default": ""
    },
    "backgroundImageId": {
      "type": "integer",
      "default": 0
    },
    "buttons": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    }
  }
}
