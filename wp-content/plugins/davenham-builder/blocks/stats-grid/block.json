{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/stats-grid",
  "version": "1.0.0",
  "title": "Stats Grid",
  "category": "davenham",
  "description": "Impact figures and headline numbers.",
  "icon": "chart-bar",
  "keywords": [
    "stats",
    "numbers",
    "metrics",
    "facts"
  ],
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": "Impact in numbers"
    },
    "items": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    }
  }
}
