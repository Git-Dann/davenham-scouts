{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/newsletter-signup",
  "version": "1.0.0",
  "title": "Newsletter Signup",
  "category": "davenham",
  "description": "Newsletter form embed or fallback signup CTA.",
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading": { "type": "string", "default": "Stay in the loop" },
    "text": { "type": "string", "default": "" },
    "embedCode": { "type": "string", "default": "" },
    "buttonText": { "type": "string", "default": "" },
    "buttonUrl": { "type": "string", "default": "" }
  }
}
