{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/cta-button-row",
  "version": "1.0.0",
  "title": "CTA Button Row",
  "category": "davenham",
  "description": "A horizontal row of CTA buttons (outline / white / green).",
  "icon": "external",
  "keywords": [
    "buttons",
    "cta",
    "call-to-action",
    "links"
  ],
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": ""
    },
    "buttons": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object"
      }
    }
  }
}
