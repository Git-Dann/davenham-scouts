{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/promo-banner",
  "version": "1.0.0",
  "title": "Promo Banner",
  "category": "davenham",
  "description": "A bold campaign banner with one clear CTA.",
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "eyebrow": { "type": "string", "default": "" },
    "heading": { "type": "string", "default": "" },
    "text": { "type": "string", "default": "" },
    "buttonText": { "type": "string", "default": "" },
    "buttonUrl": { "type": "string", "default": "" }
  }
}
