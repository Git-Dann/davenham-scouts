{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/site-notice",
  "version": "1.0.0",
  "title": "Site Notice Bar",
  "category": "davenham",
  "description": "Dismissable banner with text and an optional CTA button.",
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "text": {
      "type": "string",
      "default": ""
    },
    "buttonText": {
      "type": "string",
      "default": ""
    },
    "buttonUrl": {
      "type": "string",
      "default": "#"
    },
    "style": {
      "type": "string",
      "default": "white"
    },
    "backgroundColor": {
      "type": "string",
      "default": ""
    }
  }
}
