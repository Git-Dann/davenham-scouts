{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "davenham/page-hero",
  "version": "1.0.0",
  "title": "Page Hero",
  "category": "davenham",
  "description": "Inner-page banner (.hero.standard) with title and optional subtext.",
  "textdomain": "davenham-blocks",
  "editorScript": "davenham-blocks-editor",
  "render": "file:./render.php",
  "attributes": {
    "heading": {
      "type": "string",
      "default": ""
    },
    "subtext": {
      "type": "string",
      "default": ""
    }
  }
}
